---
title: Task 1 — Автоматизація генерації SEO-сайтів
config:
  theme: dark
  themeVariables:
    primaryColor: '#1a2332'
    primaryTextColor: '#e4e7ee'
    primaryBorderColor: '#4ea1ff'
    lineColor: '#8b93a5'
    secondaryColor: '#2a1a2a'
    tertiaryColor: '#181b22'
    background: '#0f1115'
    fontFamily: 'Inter, -apple-system, sans-serif'
    fontSize: '14px'
---
flowchart TB
    %% ───── Intake ─────
    subgraph IN["① Прийом задач"]
      direction LR
      S1["Google Sheets<br/><i>polling, writeback</i>"]
      S2["Web UI<br/><i>React dashboard</i>"]
    end

    Q[("Черга задач<br/>PostgreSQL")]

    %% ───── Data gathering ─────
    subgraph GATHER["② Збір вхідних даних"]
      direction LR
      SERP["SERP топ-10 + PAA<br/><b>DataForSEO</b><br/><i>$0.60 / 1000 запитів</i>"]
      SCR["Скрейп конкурентів<br/><b>Playwright Chromium</b><br/><i>+ Bright Data fallback</i><br/><i>для bot-protected сайтів</i>"]
      SERP --> SCR
    end

    %% ───── AI generation ─────
    subgraph GEN["③ AI генерація (per-block)"]
      direction TB
      BRIEF["Бриф сторінки<br/><b>Claude Opus 4.7</b><br/><i>H1, H2-структура, FAQ,</i><br/><i>обов'язкові сутності</i>"]
      BLOCKS["Тіло — блок за блоком<br/><b>Sonnet 4.6 / Haiku 4.5</b><br/><i>через OpenRouter</i><br/><i>per-block для селективної</i><br/><i>перегенерації</i>"]
      BRIEF --> BLOCKS
    end

    %% ───── Quality control ─────
    subgraph QC["④ Контроль якості"]
      direction LR
      RULES["Програмні правила<br/><i>density, length,</i><br/><i>schema.org валідність,</i><br/><i>KSA: 18+, Cruks,</i><br/><i>заборона знаменитостей</i>"]
      JUDGE["LLM-judge<br/><b>Sonnet 4.6</b><br/><i>тон, фактичність,</i><br/><i>банальність, відмінність</i><br/><i>від конкурентів</i>"]
      RULES --> JUDGE
    end

    %% ───── Render + publish ─────
    subgraph PUB["⑤ Збірка + публікація"]
      direction LR
      ASTRO["HTML збірка<br/><b>Astro 5</b><br/><i>schema.org JSON-LD,</i><br/><i>OG-теги, sitemap</i>"]
      CF["Деплой<br/><b>Cloudflare Pages</b><br/><i>атомарний rollout</i><br/><i>~10 секунд до CDN</i>"]
      ASTRO --> CF
    end

    STATUS["⑥ Статус назад<br/>published / failed / under_review<br/><i>URL опублікованої сторінки</i>"]

    %% ───── Storage (background) ─────
    STORE[("Спільне сховище<br/>PostgreSQL — метадані,<br/>блоки, версії, журнал<br/><br/>Cloudflare R2 — сирий<br/>HTML конкурентів,<br/>готові HTML-файли")]

    %% ───── Editorial loop ─────
    EDITOR{{"Редактор / автомоніторинг<br/><i>селективна перегенерація</i><br/><i>або точкове редагування</i><br/><i>виділеного тексту</i>"}}

    %% ───── Main flow ─────
    S1 ==> Q
    S2 ==> Q
    Q ==> GATHER
    GATHER ==> GEN
    GEN ==> QC
    QC -.->|"не пройшло<br/>→ перегенерувати"| GEN
    QC ==> PUB
    PUB ==> STATUS
    STATUS -.->|"writeback"| IN

    %% ───── Editorial feedback ─────
    PUB --> EDITOR
    EDITOR -.->|"один блок<br/>або шматок тексту"| GEN

    %% ───── Storage refs ─────
    GATHER -.- STORE
    GEN -.- STORE
    QC -.- STORE
    PUB -.- STORE

    %% ───── Styles ─────
    style IN fill:#1a2332,stroke:#4ea1ff,color:#e4e7ee
    style GATHER fill:#1f2a2a,stroke:#4dd2c7,color:#e4e7ee
    style GEN fill:#2a1a2a,stroke:#b06bff,color:#e4e7ee
    style QC fill:#332323,stroke:#ff8b3d,color:#e4e7ee
    style PUB fill:#2a2a1a,stroke:#9ad97e,color:#e4e7ee
    style STORE fill:#0f1922,stroke:#8b93a5,color:#a4adbf
    style EDITOR fill:#221a33,stroke:#ffb84e,color:#e4e7ee
