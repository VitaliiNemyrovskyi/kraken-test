# Task 1 — Редакторська петля (селективна перегенерація)
# Render: d2 --theme 200 --layout elk --pad 40 task-1-edit-loop.d2 task-1-edit-loop.svg

direction: down

published: {
  label: |md
    ### Опублікована сторінка

    Cloudflare Pages · реальний URL
  |
  style: {
    fill: "#2a2a1a"
    stroke: "#9ad97e"
    stroke-width: 3
    border-radius: 12
    font-color: "#e4e7ee"
  }
}

trigger: {
  shape: hexagon
  label: |md
    ### Тригер

    Редактор бачить проблему
    **або**
    Автомоніторинг помітив падіння позицій
  |
  style: {
    fill: "#221a33"
    stroke: "#ffb84e"
    stroke-width: 3
    font-color: "#e4e7ee"
  }
}

option_a: {
  label: |md
    ### Варіант А
    **Селективна перегенерація**

    Редактор тисне «Перегенерувати»
    біля конкретного блоку
    (наприклад FAQ)
  |
  style: {
    fill: "#2a1a2a"
    stroke: "#b06bff"
    stroke-width: 3
    border-radius: 12
    font-color: "#e4e7ee"
  }
}

option_b: {
  label: |md
    ### Варіант Б
    **Точкове редагування**

    Редактор виділяє довільний
    шматок тексту і просить
    переписати тільки його
  |
  style: {
    fill: "#2a1a2a"
    stroke: "#b06bff"
    stroke-width: 3
    border-radius: 12
    font-color: "#e4e7ee"
  }
}

regen: {
  label: |md
    ### AI генерує нову версію

    Sonnet 4.6 / Haiku 4.5 через OpenRouter

    Використовує оригінальний бриф
    + коментар редактора
    + контекст сусідніх блоків
  |
  style: {
    fill: "#2a1a2a"
    stroke: "#b06bff"
    stroke-width: 3
    border-radius: 12
    font-color: "#e4e7ee"
  }
}

preview: {
  label: |md
    ### Перегляд змін

    Side-by-side порівняння
    стара ↔ нова версія
  |
  style: {
    fill: "#332323"
    stroke: "#ff8b3d"
    stroke-width: 3
    border-radius: 12
    font-color: "#e4e7ee"
  }
}

decision: {
  shape: diamond
  label: |md
    Прийняти?
  |
  style: {
    fill: "#1f2a2a"
    stroke: "#4dd2c7"
    stroke-width: 3
    font-color: "#e4e7ee"
  }
}

rebuild: {
  label: |md
    ### Перезбірка + деплой

    Astro перебирає сторінку
    з новим блоком
    Cloudflare Pages підхоплює
    за ~10 секунд
  |
  style: {
    fill: "#2a2a1a"
    stroke: "#9ad97e"
    stroke-width: 3
    border-radius: 12
    font-color: "#e4e7ee"
  }
}

rollback: {
  label: |md
    ### Старий блок залишається

    Нова версія записується
    з позначкою rejected
    у журналі
  |
  style: {
    fill: "#1a2332"
    stroke: "#8b93a5"
    stroke-width: 2
    border-radius: 12
    font-color: "#cdd2db"
  }
}

# Звʼязки
published -> trigger
trigger -> option_a
trigger -> option_b
option_a -> regen
option_b -> regen
regen -> preview
preview -> decision
decision -> rebuild: "так"
decision -> rollback: "ні"
