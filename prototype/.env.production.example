# Production .env — copy to .env on the server and fill in real values.
# Keep this file out of git (already in .gitignore via .env entry).

# Required for SERP_SOURCE=serpapi
SERPAPI_KEY=

# Required for CLASSIFIER_LLM_ENABLED=true
OPENROUTER_API_KEY=

# Optional overrides — defaults are fine for most deploys
# QUERY=starcasino
# GEO=Netherlands
# BRAND_DOMAIN=starcasino.nl
# SERP_LIMIT=10
# MONITOR_CRON="0 */6 * * *"
# OPENROUTER_MODEL=anthropic/claude-opus-4-7
