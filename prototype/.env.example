# SERP source — 'serpapi' | 'playwright' | 'mock'
SERP_SOURCE=mock

# SerpAPI (free tier: 100 searches/month — get key at serpapi.com)
SERPAPI_KEY=

# Brand monitoring target
BRAND_DOMAIN=starcasino.nl
QUERY=starcasino
GEO=Netherlands
GOOGLE_DOMAIN=google.nl
HL=nl
GL=nl
SERP_LIMIT=10

# Classifier
CLASSIFIER_LLM_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4-7

# Scraper
SCRAPER_TIMEOUT_MS=15000
SCRAPER_CONCURRENCY=3
SCRAPER_RATE_PER_DOMAIN_MS=1000

# Dashboard
PORT=3000
HOST=127.0.0.1

# Storage
DATABASE_PATH=./data/starcasino.db

# Scheduler — auto-started by `npm run dashboard` unless MONITOR_CRON=off.
# Default "0 */6 * * *" = every 6 hours (production-realistic, fits SerpAPI free tier).
# Use UI Settings drawer to change at runtime.
# For demos: MONITOR_CRON="*/30 * * * * *" (6-field cron with seconds = every 30 sec).
MONITOR_CRON=0 */6 * * *
RUN_ON_START=true
