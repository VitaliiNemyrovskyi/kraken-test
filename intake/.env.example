# Google OAuth 2.0 (required for Sheets intake)
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Sheets configuration
# After OAuth, paste a Sheet ID and tab range here, or configure via UI.
# Default schema columns (row 1 = headers):
#   id | keyword | geo | language | brand | content_type | status | output_url
SHEET_ID=
SHEET_RANGE=Sheet1!A:H

# Polling
POLL_INTERVAL_SECONDS=60

# Server
PORT=3001
HOST=127.0.0.1

# Data
DATABASE_PATH=./data/intake.db
